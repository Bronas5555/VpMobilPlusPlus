<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localControls="clr-namespace:VpMobilPlusPlus.UserControls.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VpMobilPlusPlus.UserControls.Pages.StartPage">
    <Grid 
        Margin="5"
        RowDefinitions="Auto, *"
        ColumnDefinitions="*">
        <Grid
            DockPanel.Dock="Top" 
            ColumnDefinitions="*, Auto"
            Grid.Row="0">
            <TextBlock Grid.Column="0" 
                Text="VpMobil++"
                FontSize="32"
                HorizontalAlignment="Left"
                Margin="5"></TextBlock>
            <Button 
                Grid.Column="1" 
                HorizontalAlignment="Right" 
                Margin="0 0 5 0"
                Name="SettingsButton">Settings</Button>
        </Grid>
        
        <ScrollViewer
            Grid.Row="1"
            HorizontalAlignment="Stretch">
            <StackPanel 
                Name="ClassList" 
                Margin="12"
                HorizontalAlignment="Stretch">
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
