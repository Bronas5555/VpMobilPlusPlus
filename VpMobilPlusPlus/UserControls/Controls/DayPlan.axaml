<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localControls="clr-namespace:VpMobilPlusPlus.UserControls.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VpMobilPlusPlus.UserControls.Controls.DayPlan">
    <Border BorderBrush="White" BorderThickness="1" CornerRadius="4">
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="DimGray" CornerRadius="4">
                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        Margin="10"
                        Text="" 
                        HorizontalAlignment="Center"
                        Name="DateBlock"></TextBlock>
                    <Button
                        Name="InfoButton"
                        IsVisible="False"
                        Margin="5"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right">Info</Button>
                </DockPanel>
            </Border>
            
            <Grid RowDefinitions="*, *, *, *, *, *" Name="CourseList">
            </Grid>
        </DockPanel>
    </Border>
</UserControl>