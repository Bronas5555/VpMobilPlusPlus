<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:VpMobilPlusPlus.UserControls.Pages"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VpMobilPlusPlus.Views.MainView">
    
    <Panel>
        <local:StartPage IsVisible="True" Name="StartPage"></local:StartPage>
        <local:PlanPage IsVisible="False" Name="PlanPage"></local:PlanPage>
        <local:CourseColorSelectionPage IsVisible="False" Name="ColorPage"></local:CourseColorSelectionPage>
        <local:CourseFilterPage Name="FilterPage" IsVisible="False"></local:CourseFilterPage>
        <local:SettingsPage Name="SettingsPage" IsVisible="False"></local:SettingsPage>
    </Panel>
</UserControl>
